{% extends 'base.html.twig' %}

{% block title %}Gestion des compétences - Entr'Aide 2.0{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-lg skill-card">
                <div class="card-header text-white py-4" style="background-color: #4CAF50;">
                    <h2 class="h3 mb-0 fw-bold"><i class="bi bi-patch-check me-2"></i>Gestion des compétences</h2>
                </div>
                <div class="card-body px-lg-5 py-4">
                    {{ form_start(form) }}
                        <div class="mb-4">
                            {{ form_row(form.skills, {
                                label: 'Sélectionnez vos compétences :',
                                attr: { class: 'skill-list' },
                                row_attr: { class: 'form-group' },
                                label_attr: { class: 'form-label fw-medium mb-3 h5' }
                            }) }}
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-semibold">
                                <i class="bi bi-save2 me-2"></i>Enregistrer
                            </button>
                            <a href="{{ path('app_profile_index') }}" 
                               class="btn btn-outline-secondary btn-lg rounded-pill fw-semibold">
                                <i class="bi bi-arrow-left me-2"></i>Retour
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}