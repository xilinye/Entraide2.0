<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Entr'aide 2.0{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('styles/styles.css') }}">
</head>
<body>
    <header>
        <div class="logo">Entr'aide 2.0</div>
        <nav>
            <ul>
                {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                    <li><a href="{{ path('app_profile') }}">Profil</a></li>
                    <li><a href="{{ path('app_search') }}">Recherche</a></li>
                    <li><a href="{{ path('app_logout') }}">Déconnexion</a></li>
                {% else %}
                    <li><a href="{{ path('app_home') }}">Accueil</a></li>
                    <li><a href="{{ path('app_login') }}">Connexion</a></li>
                {% endif %}
            </ul>
        </nav>
    </header>

    <main>
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% block body %}{% endblock %}
    </main>

    <footer>
        <p>&copy; {{ 'now'|date('Y') }} Entr'aide 2.0</p>
        <ul>
            <li><a href="{{ path('app_about') }}">À propos</a></li>
            <li><a href="{{ path('app_contact') }}">Contact</a></li>
            <li><a href="{{ path('app_terms') }}">Conditions d'utilisation</a></li>
        </ul>
    </footer>
</body>
</html>